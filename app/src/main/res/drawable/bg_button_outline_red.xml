<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Nền trong suốt -->
    <solid android:color="@android:color/transparent"/>

    <!-- Viền màu đỏ dày 2dp -->
    <stroke
        android:width="2dp"
        android:color="#F44336"/>

    <!-- Bo góc 12dp -->
    <corners android:radius="12dp"/>

    <!-- Padding cho chữ -->
    <padding
        android:left="16dp"
        android:top="12dp"
        android:right="16dp"
        android:bottom="12dp"/>
</shape>