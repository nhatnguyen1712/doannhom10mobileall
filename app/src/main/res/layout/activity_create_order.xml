<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2E7D32"
        app:title="Tạo đơn thuốc"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- THÔNG TIN BỆNH NHÂN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN BỆNH NHÂN"
                android:textColor="#2E7D32"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Họ tên bệnh nhân -->
            <EditText
                android:id="@+id/etPatientName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Họ tên bệnh nhân *"
                android:background="@drawable/bg_edit_text"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>

            <!-- Tuổi và Giới tính -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/etPatientAge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Tuổi *"
                    android:inputType="number"
                    android:background="@drawable/bg_edit_text"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp"/>

                <RadioGroup
                    android:id="@+id/radioGroupGender"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_edit_text"
                    android:padding="8dp"
                    android:layout_marginStart="4dp">

                    <RadioButton
                        android:id="@+id/radioMale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nam"
                        android:checked="true"
                        android:textColor="#212121"/>

                    <RadioButton
                        android:id="@+id/radioFemale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nữ"
                        android:textColor="#212121"/>
                </RadioGroup>
            </LinearLayout>

            <!-- Địa chỉ -->
            <EditText
                android:id="@+id/etPatientAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Địa chỉ"
                android:background="@drawable/bg_edit_text"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>

            <!-- Số điện thoại -->
            <EditText
                android:id="@+id/etPatientPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Số điện thoại"
                android:inputType="phone"
                android:background="@drawable/bg_edit_text"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>

            <!-- Chuẩn đoán bệnh -->
            <EditText
                android:id="@+id/etDiagnosis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Chuẩn đoán bệnh *"
                android:background="@drawable/bg_edit_text"
                android:padding="12dp"
                android:layout_marginBottom="16dp"/>

            <!-- BÁC SĨ KHÁM -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BÁC SĨ KHÁM"
                android:textColor="#2E7D32"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etDoctorName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Tên bác sĩ"
                    android:background="@drawable/bg_edit_text"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngày: 17/03/2024"
                    android:textColor="#757575"
                    android:gravity="center_vertical"
                    android:padding="12dp"/>
            </LinearLayout>

            <!-- THUỐC KÊ ĐƠN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="THUỐC KÊ ĐƠN"
                android:textColor="#2E7D32"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Nút thêm thuốc -->
            <Button
                android:id="@+id/btnAddDrug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="+ THÊM THUỐC"
                android:textColor="#2E7D32"
                android:background="@drawable/bg_button_outline"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- RecyclerView hiển thị danh sách thuốc đã chọn -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"/>

            <!-- Tổng tiền -->
            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tổng tiền: 0 đ"
                android:textColor="#2E7D32"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="end"
                android:layout_marginBottom="16dp"/>

            <!-- Buttons Lưu và Hủy -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LƯU ĐƠN"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2E7D32"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="HỦY"
                    android:textColor="#F44336"
                    android:background="@drawable/bg_button_outline_red"
                    android:padding="12dp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- Nút Back (nếu cần) -->
            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="QUAY LẠI"
                android:textColor="#2E7D32"
                android:background="@android:color/transparent"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>